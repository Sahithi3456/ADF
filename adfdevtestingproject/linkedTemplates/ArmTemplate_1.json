		"textadls001_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'textadls001'"
		},
		"textblob001_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'textblob001'"
		},
		"textsink_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'textsink'"
		},
		"textsource_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'textsource'"
		},
		"txtblob_connectionString": {
