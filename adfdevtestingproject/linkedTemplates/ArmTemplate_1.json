			"metadata": "Secure string for 'connectionString' of 'txtblob'"
		},
		"csvadls001_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevtestproject001.dfs.core.windows.net/"
		},
		"outpuradlscsv_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevtestproject001.dfs.core.windows.net/"
