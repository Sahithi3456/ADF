			"defaultValue": "adfdevtestingproject"
		},
		"csvadls001_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'csvadls001'"
		},
		"csvbinary_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'csvbinary'"
		},
		"csvblob_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'csvblob'"
		},
		"csvcopy001blob_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'csvcopy001blob'"
		},
		"csvsource_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'csvsource'"
		},
		"ls_binary_connectionString": {
			"type": "secureString",
