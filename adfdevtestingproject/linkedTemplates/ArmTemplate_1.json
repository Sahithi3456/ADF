				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('textsink_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('textsink_accountKey')]"
					}
				}
			},
			"dependsOn": []
