{
	"name": "csvsource",
	"properties": {
		"linkedServiceName": {
			"referenceName": "csvsource",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"sourcefile": {
				"type": "String"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"fileName": {
					"value": "@dataset().sourcefile",
					"type": "Expression"
				},
				"container": "inputcsv"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "SIC_Code",
				"type": "String"
			},
			{
				"name": "Description",
				"type": "String"
			}
		]
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}